## SocialGuard-RL environment variables
##
## Copy to `.env` for local development and adjust as needed.

# Optional: protect the Streamlit dashboard with a simple shared secret.
# If set, the dashboard requires this token to be entered in the sidebar.
SOCIALGUARD_DASHBOARD_TOKEN=CHANGE_THIS_BEFORE_DEPLOYING

HF_TOKEN=hf_your_token_here
MASTODON_ACCESS_TOKEN=your_mastodon_token_here
API_BASE_URL=https://api-inference.huggingface.co/v1
MODEL_NAME=Qwen/Qwen3-30B-A3B
